# ============================================================
# OpenCode Client 前端配置文件
# ============================================================

# API 基础 URL
# 开发环境: http://localhost:8000
# 生产环境: 填写你的后端服务器地址
VITE_API_BASE_URL=http://localhost:8000

# OpenCode 服务地址（用于 AI 分析功能）
# 本地开发: http://localhost:4096
# 生产环境: 填写实际的 OpenCode 服务地址
VITE_OPENCODE_URL=http://localhost:4096

# 应用标题
VITE_APP_TITLE=OpenCode Client

# 是否启用调试模式
VITE_DEBUG=false
